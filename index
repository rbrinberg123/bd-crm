.dv-sortable:hover { color: var(--color-text-primary); }
.dv-sortable svg { width: 10px; height: 10px; opacity: 0.5; }
.dv-tbody { display: flex; flex-direction: column; min-width: max-content; }
.dv-tr {
  display: grid;
  grid-template-columns:
    minmax(160px, 1.1fr)
    minmax(62px, 0.4fr)
    minmax(46px, 0.3fr)
    minmax(140px, 0.9fr)
    minmax(140px, 0.8fr)
    minmax(100px, 0.6fr)
    minmax(80px, 0.5fr)
    minmax(60px, 0.35fr)
    minmax(220px, 1.2fr)
    minmax(310px, 1.6fr)
  ;
  border-bottom: 0.5px solid var(--color-border-tertiary);
  cursor: pointer;
  transition: background 0.12s;
  align-items: center;
}
.dv-tr:last-child { border-bottom: none; }
.dv-tr:hover { background: var(--hover-bg); }
.dv-tr.stalled { opacity: 0.55; }
.dv-tr.stalled:hover { opacity: 0.85; }
.dv-tr.lost { opacity: 0.45; }
.dv-tr.lost:hover { opacity: 0.7; }

.dv-td { padding: 9px 11px; font-size: 12px; color: var(--color-text-primary); display: flex; align-items: center; gap: 6px; min-width: 0; }
.dv-co { font-weight: 500; }
.dv-tk { font-family: ui-monospace, monospace; font-size: 11px; color: var(--color-text-secondary); font-weight: 500; letter-spacing: 0.02em; padding: 1px 5px; background: var(--crm-grey-bg); border-radius: 3px; }
.dv-hq { color: var(--color-text-secondary); font-size: 11px; font-weight: 500; letter-spacing: 0.04em; }
.dv-stage-stalled { font-style: italic; color: var(--color-text-tertiary); font-size: 11px; }
.dv-next { font-size: 11px; color: var(--color-text-secondary); white-space: nowrap; }
.dv-co-name { white-space: nowrap; }
.dv-deal { color: var(--color-text-secondary); font-size: 12px; white-space: nowrap; }
.dv-stage { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; }
.dv-stage-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.dv-stalled-chip {
  display: inline-block;
  font-size: 10px; padding: 1px 5px;
  background: var(--crm-grey-bg); color: var(--crm-grey-text);
  border-radius: 3px; font-weight: 500;
  margin-left: 5px;
}
.dv-val { font-weight: 500; font-variant-numeric: tabular-nums; }
.dv-cur-tag { color: var(--color-text-tertiary); font-size: 10px; font-weight: 400; margin-left: 3px; letter-spacing: 0.03em; }
.dv-av {
  width: 22px; height: 22px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 500;
  flex-shrink: 0;
  border: 0.5px solid var(--color-border-tertiary);
  background: var(--crm-grey-bg); color: var(--crm-grey-text);
}
.dv-days { font-variant-numeric: tabular-nums; color: var(--color-text-secondary); }
.dv-days.warn { color: var(--color-text-warning); font-weight: 500; }
.dv-days.danger { color: var(--color-text-danger); font-weight: 500; }
.dv-flag {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 11px; font-weight: 500;
  white-space: nowrap;
}
.dv-flag-text { white-space: nowrap; }
.dv-flag-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }

/* Kanban view */
.dv-kb {
  display: grid;
  grid-template-columns: repeat(5, minmax(190px, 1fr));
  gap: 10px;
  margin-bottom: 20px;
}
.dv-kc {
  background: var(--color-background-secondary);
  border-radius: 8px;
  padding: 10px;
  display: flex; flex-direction: column; gap: 7px;
  min-height: 140px;
}
.dv-kc-h {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0 4px 6px;
  font-size: 11px; font-weight: 500;
  color: var(--color-text-secondary);
  letter-spacing: 0.02em;
  border-bottom: 0.5px solid var(--color-border-tertiary);
  margin-bottom: 3px;
}
.dv-kc-c { color: var(--color-text-tertiary); font-weight: 400; }
.dv-kc-h-left { display: inline-flex; align-items: center; gap: 6px; }
.dv-kc-dot { width: 7px; height: 7px; border-radius: 50%; }
.dv-card {
  background: var(--color-background-primary);
  border: 0.5px solid var(--color-border-tertiary);
  border-radius: 6px;
  padding: 9px 10px;
  cursor: pointer;
  transition: background 0.12s, border-color 0.12s;
  display: flex; flex-direction: column; gap: 4px;
}
.dv-card:hover { border-color: var(--color-border-secondary); }
.dv-card.stalled { opacity: 0.55; }
.dv-card.stalled:hover { opacity: 0.85; }
.dv-card.lost { opacity: 0.45; }
.dv-card-co { font-size: 12px; font-weight: 500; color: var(--color-text-primary); line-height: 1.3; }
.dv-card-deal { font-size: 11px; color: var(--color-text-secondary); line-height: 1.3; }
.dv-card-row { display: flex; justify-content: space-between; align-items: center; gap: 6px; margin-top: 2px; }
.dv-card-val { font-size: 12px; font-weight: 500; color: var(--color-text-primary); font-variant-numeric: tabular-nums; }
.dv-card-cur { color: var(--color-text-tertiary); font-size: 10px; font-weight: 400; margin-left: 2px; letter-spacing: 0.03em; }
.dv-card-meta {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 10px; color: var(--color-text-tertiary);
}
.dv-card-meta-l { display: inline-flex; align-items: center; gap: 4px; }
.dv-card-flag-dot { width: 6px; height: 6px; border-radius: 50%; }

@media (max-width: 1100px) {
  .dv-kb { grid-template-columns: repeat(3, minmax(190px, 1fr)); }
