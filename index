function closeCreateDeal() {
  document.getElementById('modal-create-deal').hidden = true;
}

const NAME_OPTIONS_BY_TYPE = {
  'Annual retainer': ['Investor access'],
  'Project': ['Perception study', 'Investor day']
};

function populateNameOptions(type) {
  const dd = document.getElementById('cd-name-dropdown');
  const input = document.getElementById('cd-name-input');
  const opts = NAME_OPTIONS_BY_TYPE[type] || [];
  dd.innerHTML = opts.map(o => `<div class="combo-item" data-name="${o}">${o}</div>`).join('') +
    '<div class="combo-item custom" data-name="__custom">Custom (type your own)</div>';
  const allPresets = Object.values(NAME_OPTIONS_BY_TYPE).flat();
  if (!input.value || allPresets.includes(input.value)) {
    input.value = opts[0] || '';
  }
  // Wire up click handlers on the new items
  dd.querySelectorAll('.combo-item').forEach(item => {
    item.addEventListener('click', () => {
      const name = item.dataset.name;
      if (name === '__custom') {
        input.value = '';
        input.focus();
      } else {
        input.value = name;
      }
      dd.hidden = true;
    });
  });
}

function toggleNameDropdown(e) {
  e.stopPropagation();
  const dd = document.getElementById('cd-name-dropdown');
  dd.hidden = !dd.hidden;
}

document.querySelectorAll('input[name="cd-type"]').forEach(r => {
  r.addEventListener('change', () => {
    if (!r.checked) return;
    populateNameOptions(r.value);
  });
});

function toggleAdvanced() {
  const exp = document.getElementById('cd-expander');
  const content = document.getElementById('cd-advanced');
  exp.classList.toggle('open');
  content.classList.toggle('open');
}

function autofillNextStep() {
  const temp = document.getElementById('cd-temp').value;
  const nextField = document.getElementById('cd-next');
  if (temp && TEMP_NEXT_MAP[temp] && !nextField.value) {
    nextField.value = TEMP_NEXT_MAP[temp];
  }
}

function submitCreateDeal() {
  const company = document.getElementById('cd-company').value;
  const type = document.querySelector('input[name="cd-type"]:checked').value;
  const dealName = document.getElementById('cd-name-input').value.trim();
  const value = parseFloat(document.getElementById('cd-value').value) || 0;
  const currency = document.getElementById('cd-currency').value;
  const stage = document.getElementById('cd-stage').value;
  const owner = document.getElementById('cd-owner').value;
  const ownerName = document.querySelector(`#cd-owner option[value="${owner}"]`).textContent;
  const temp = document.getElementById('cd-temp').value;
  const nextStep = document.getElementById('cd-next').value || (temp ? TEMP_NEXT_MAP[temp] : '');
  const notes = document.getElementById('cd-notes').value;

  if (!company || !value) { alert('Company and value are required'); return; }
  if (!dealName) { alert('Deal name is required'); return; }

  const meta = COMPANY_TICKERS[company] || { ticker: '????', hq: 'US' };

  const newDeal = {
    id: nextDealId++,
    company,
    ticker: meta.ticker,
    hq: meta.hq,
    deal: dealName,
    type,
    stage,
    value,
    currency,
    owner,
    ownerName,
    days: 0,
    stalledDays: 0,
    temperature: temp || null,
    nextStep: nextStep || '',
    notes: notes || ''
  };
  DEALS.push(newDeal);
  closeCreateDeal();
  renderDeals();
}

// ========== VIEW/EDIT DEAL DRAWER ==========
function openDealDrawer(dealId) {
  const deal = DEALS.find(d => d.id === dealId);
  if (!deal) return;
  document.getElementById('drawer-deal').hidden = false;
  renderDealDrawer(deal);
}

function closeDealDrawer() {
  document.getElementById('drawer-deal').hidden = true;
}

function renderDealDrawer(d) {
  const sc = STAGE_COLORS[d.stage] || { dot: '#9CA3AF', text: '#6B7280' };
  const isStalled = d.stalledDays > 0;
  const temp = parseTemp(d.temperature);
  const tempDisplay = temp
    ? `<span style="color:${FLAG_COLORS[temp.color].text}; font-weight:500;" title="${d.temperature}"><span style="display:inline-block; width:7px; height:7px; border-radius:50%; background:${FLAG_COLORS[temp.color].dot}; margin-right:5px; vertical-align:1px;"></span>${temp.reason || (temp.color.charAt(0).toUpperCase() + temp.color.slice(1))}</span>`
    : '<span style="color:var(--color-text-tertiary)">Click to add</span>';

  const stageDisplay = isStalled
    ? `<span class="dr-stage-pill" style="background:var(--color-background-secondary); color:var(--color-text-tertiary); font-style:italic;">Stalled · ${d.stalledDays}d</span>`
    : `<span class="dr-stage-pill" style="background:${sc.dot}22; color:${sc.text};"><span class="dot" style="background:${sc.dot}"></span>${d.stage}</span>`;

  const html = `
    <div class="m-head">
      <div style="flex:1; min-width:0">
        <div class="dr-bc" style="margin-bottom:4px;"><span class="dr-bc-co" onclick="closeDealDrawer(); showPage('page-company');">${d.company}</span> · ${d.ticker} · ${d.hq}</div>
        <div class="m-title" style="font-size:15px;">${d.deal}</div>
      </div>
      <div style="display:flex; gap:4px; align-items:center; flex-shrink:0;">
        <div class="am-wrap">
          <button class="am-btn" onclick="toggleActionMenu(event, ${d.id})" title="Actions"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg></button>
          <div class="am-menu" id="am-menu-${d.id}">
            <div class="am-item" onclick="markDealStage(${d.id}, 'Won')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>Mark as Won</div>
            <div class="am-item" onclick="markDealStage(${d.id}, 'Lost')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>Mark as Lost</div>
            <div class="am-item" onclick="markDealStalled(${d.id})"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>${isStalled ? 'Un-stall' : 'Mark as Stalled'}</div>
            <div class="am-divider"></div>
            <div class="am-item danger" onclick="deleteDeal(${d.id})"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/></svg>Delete deal</div>
          </div>
        </div>
        <button class="m-x" onclick="closeDealDrawer()" title="Close"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
    </div>

    <div class="m-body">
      <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap; margin-bottom:14px;">
        ${stageDisplay}
        <span style="font-size:14px; font-weight:500;">${fmtValue(d.value)}<span style="color:var(--color-text-tertiary); font-size:11px; margin-left:3px; letter-spacing:0.03em;">${d.currency}</span></span>
        <span style="color:var(--color-text-tertiary); font-size:11px;">·</span>
        <span style="font-size:12px; color:var(--color-text-secondary);">${d.type || (d.deal === 'Investor access' ? 'Annual retainer' : 'Project')}</span>
      </div>

      <div class="ed-grid" style="margin-bottom:12px;">
        <div>
          <div class="ed-cell-l">Days since sent</div>
          <div style="font-size:13px; font-weight:500; padding:6px 0;">${d.days}d ${isStalled ? `<span style="color:var(--color-text-tertiary); font-style:italic; font-weight:400; font-size:11px;"> · Stalled ${d.stalledDays}d</span>` : ''}</div>
        </div>
        <div>
          <div class="ed-cell-l">Sent by</div>
          <div style="font-size:13px; padding:6px 0; display:flex; align-items:center; gap:6px;">
            <span class="dv-av" title="${d.ownerName}">${d.owner}</span>
            <span>${d.ownerName}</span>
          </div>
        </div>
      </div>

      <div class="ed-grid" style="margin-bottom:12px;">
        <div>
          <div class="ed-cell-l">Temperature</div>
          <div class="ed-cell" data-deal-id="${d.id}" data-field="temperature" onclick="editField(this, ${d.id}, 'temperature')">
            <span class="ed-cell-v">${tempDisplay}</span>
          </div>
        </div>
        <div>
          <div class="ed-cell-l">Follow-up</div>
          <div class="ed-cell" data-deal-id="${d.id}" data-field="nextStep" onclick="editField(this, ${d.id}, 'nextStep')">
            <span class="ed-cell-v">${d.nextStep || '<span style="color:var(--color-text-tertiary)">Click to add</span>'}</span>
          </div>
        </div>
      </div>

      <div>
        <div class="ed-cell-l" style="margin-bottom:5px;">Notes</div>
        <div class="ed-cell" data-deal-id="${d.id}" data-field="notes" onclick="editField(this, ${d.id}, 'notes')" style="min-height:40px;">
          <span class="ed-cell-v" style="white-space:pre-wrap;">${d.notes || '<span style="color:var(--color-text-tertiary)">Click to add notes...</span>'}</span>
        </div>
      </div>
    </div>
  `;
  document.getElementById('drawer-content').innerHTML = html;
}

function toggleActionMenu(e, dealId) {
  e.stopPropagation();
  const menu = document.getElementById(`am-menu-${dealId}`);
  document.querySelectorAll('.am-menu.open').forEach(m => { if (m !== menu) m.classList.remove('open'); });
  menu.classList.toggle('open');
}

function markDealStage(dealId, stage) {
  const deal = DEALS.find(d => d.id === dealId);
  if (!deal) return;
  if (stage === 'Won') {
    if (!confirm('Won deals will hand off to delivery. Continue?')) return;
    deal.stage = 'Won';
    deal.stalledDays = 0;
  } else if (stage === 'Lost') {
    const reason = prompt('Reason for loss?\n\nType "said no" or "ghosted":');
    if (!reason) return;
    deal.stage = 'Lost';
    deal.stalledDays = 0;
    deal.lossReason = reason.toLowerCase().includes('ghost') ? 'ghosted' : 'said no';
  }
  renderDealDrawer(deal);
  renderDeals();
}

function markDealStalled(dealId) {
  const deal = DEALS.find(d => d.id === dealId);
  if (!deal) return;
  deal.stalledDays = deal.stalledDays > 0 ? 0 : 1;
  renderDealDrawer(deal);
  renderDeals();
}

function deleteDeal(dealId) {
  if (!confirm('Delete this deal? This cannot be undone.')) return;
  const idx = DEALS.findIndex(d => d.id === dealId);
  if (idx >= 0) DEALS.splice(idx, 1);
  closeDealDrawer();
  renderDeals();
}

function editField(cell, dealId, field) {
  if (cell.classList.contains('editing')) return;
  const deal = DEALS.find(d => d.id === dealId);
  if (!deal) return;
  cell.classList.add('editing');
  const current = deal[field] || '';

  let inputHtml;
  if (field === 'temperature') {
    const opts = ['', ...Object.keys(TEMP_NEXT_MAP)];
    inputHtml = `<select>${opts.map(o => {
      const p = o ? parseTemp(o) : null;
      const label = p?.reason || o || '— Not set —';
      return `<option value="${o}" ${o === current ? 'selected' : ''}>${label}</option>`;
    }).join('')}</select>`;
  } else if (field === 'notes') {
    inputHtml = `<textarea>${current}</textarea>`;
  } else {
    inputHtml = `<input type="text" value="${current.replace(/"/g, '&quot;')}">`;
  }
  cell.innerHTML = inputHtml;
  const input = cell.querySelector('input, select, textarea');
  input.focus();
  if (input.select) input.select();

  const commit = () => {
    deal[field] = input.value;
    // Auto-update next step when temperature changes
    if (field === 'temperature' && input.value && TEMP_NEXT_MAP[input.value]) {
      deal.nextStep = TEMP_NEXT_MAP[input.value];
    }
    renderDealDrawer(deal);
    renderDeals();
  };
  input.addEventListener('blur', commit);
  input.addEventListener('keydown', e => {
    if (e.key === 'Enter' && field !== 'notes') { e.preventDefault(); input.blur(); }
    if (e.key === 'Escape') { e.preventDefault(); renderDealDrawer(deal); }
  });
}

// Close modal/drawer on scrim click
document.getElementById('modal-create-deal').addEventListener('click', e => {
  if (e.target.id === 'modal-create-deal') closeCreateDeal();
});
document.getElementById('drawer-deal').addEventListener('click', e => {
  if (e.target.id === 'drawer-deal') closeDealDrawer();
});

// ESC closes
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if (!document.getElementById('modal-create-deal').hidden) closeCreateDeal();
    if (!document.getElementById('drawer-deal').hidden) closeDealDrawer();
  }
});


// Close dropdowns on outside click
document.addEventListener('click', () => {
  document.querySelectorAll('.dv-menu.open, .am-menu.open').forEach(m => m.classList.remove('open'));
  // Close the deal name combo dropdown if clicking outside it
  const ddName = document.getElementById('cd-name-dropdown');
  if (ddName && !ddName.hidden) {
    const wrap = ddName.closest('.combo-wrap');
    if (wrap && !wrap.contains(event.target)) ddName.hidden = true;
  }
});

// Stop propagation on inner buttons so they don't trigger row click
document.querySelectorAll('.p-act, .m-act').forEach(btn => {
  btn.addEventListener('click', e => e.stopPropagation());
});
