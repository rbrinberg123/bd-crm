// Parse temperature string like "Yellow Flag (Budget Concern)" into { color, reason }
function parseTemp(t) {
  if (!t) return null;
  const m = t.match(/^(Green|Yellow|Red) Flag(?: \(([^)]+)\))?$/i);
  if (!m) return null;
  const color = m[1].toLowerCase();
  let reason = m[2] || '';
  // Strip "Other: " prefix from reasons like "Other: Limited Intent"
  reason = reason.replace(/^Other:\s*/i, '');
  return { color, reason };
}

