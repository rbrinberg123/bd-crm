// ========== EXCEL-STYLE HEADER COLUMN FILTERS + SORT ==========
// Each column registers a config: how to sort, how to enumerate options, where state lives.
//
// State model: each table has sort[] (ordered list for secondary sort) and filters{} (Set of allowed values per column).
// Sort entry: { col: 'days', dir: 'desc' }
// Filter: filterStateKey → Set of strings (or 'all' meaning everything)

const HEADER_FILTERS = {
  // ----- DEALS COLUMNS -----
  'deals-stage': {
    table: 'deals', label: 'Stage', type: 'cat',
    valueOf: (d) => d.stage,
    options: () => ['In conversation', 'Proposal', 'Contract', 'Won', 'Lost'].map(s => ({ value: s, label: s, dot: STAGE_COLORS[s]?.dot }))
  },
  'deals-owner': {
    table: 'deals', label: 'Owner', type: 'cat',
    valueOf: (d) => d.owner,
    options: () => {
      const owners = [...new Set(DEALS.map(d => d.owner))];
      return owners.map(o => ({ value: o, label: (DEALS.find(d => d.owner === o)?.ownerName || o) + ' (' + o + ')' }));
    }
  },
  'deals-value':       { table: 'deals', label: 'Value', type: 'num', valueOf: (d) => d.value },
  'deals-days':        { table: 'deals', label: 'Days', type: 'num', valueOf: (d) => d.days },
  'deals-temperature': {
    table: 'deals', label: 'Temperature', type: 'cat',
    valueOf: (d) => d.temperature || '',
    options: () => {
      const all = [...new Set(DEALS.map(d => d.temperature).filter(Boolean))].sort();
      return all.map(t => {
        const parsed = parseTemp(t);
        const label = parsed?.reason || t;
        return { value: t, label, dot: parsed ? FLAG_COLORS[parsed.color]?.dot : null };
      });
    }
  },

  // ----- COMPANIES COLUMNS -----
  'cv-mktcap': {
    table: 'companies', label: 'Mkt cap', type: 'num',
    valueOf: (c) => parseMktCap(c.mktCap)
  },
  'cv-sector': {
    table: 'companies', label: 'Sector', type: 'cat',
    valueOf: (c) => c.sector,
    options: () => [...new Set(COMPANY_DATA.map(c => c.sector))].sort().map(s => ({ value: s, label: s }))
  },
  'cv-hq': {
    table: 'companies', label: 'HQ', type: 'cat',
    valueOf: (c) => c.hq,
    options: () => [...new Set(COMPANY_DATA.map(c => c.hq))].sort().map(h => ({ value: h, label: h }))
  },
  'cv-stage': {
    table: 'companies', label: 'Stage', type: 'cat',
    valueOf: (c) => c.stage,
    options: () => ['Cold', 'Aware', 'Engaged', 'Current client', 'Past client', 'Dormant', 'Declined', 'Lost'].map(s => ({ value: s, label: s, dot: COMPANY_STAGE_COLORS[s]?.dot }))
  },
  'cv-owner': {
    table: 'companies', label: 'Owner', type: 'cat',
    valueOf: (c) => c.owner,
    options: () => {
      const owners = [...new Set(COMPANY_DATA.map(c => c.owner))];
      return owners.map(o => ({ value: o, label: (COMPANY_DATA.find(c => c.owner === o)?.ownerName || o) + ' (' + o + ')' }));
    }
  },
  'cv-days':    { table: 'companies', label: 'Days', type: 'num', valueOf: (c) => c.days },
  'cv-tasks':   { table: 'companies', label: 'Tasks', type: 'num', valueOf: (c) => c.tasks },
  'cv-earn':    { table: 'companies', label: 'Next earnings', type: 'date', valueOf: (c) => c.nextEarn }
};

function parseMktCap(s) {
  if (!s) return 0;
  const m = s.match(/\$([\d.]+)([MB]?)/);
  if (!m) return 0;
  return parseFloat(m[1]) * (m[2] === 'B' ? 1000 : 1);
}

// Per-table sort + filter state
const tableState = {
  deals: { sort: [{ col: 'deals-stage', dir: 'asc' }], filters: {} },     // default sort by stage asc
  companies: { sort: [{ col: 'cv-days', dir: 'desc' }], filters: {} }     // default sort by days desc
};

function getColumnFilter(filterId) {
  const cfg = HEADER_FILTERS[filterId];
  if (!cfg) return null;
  return tableState[cfg.table].filters[filterId] || null;
}

function passesColumnFilters(table, item) {
  const filters = tableState[table].filters;
  for (const [filterId, allowed] of Object.entries(filters)) {
    if (!allowed) continue;
    const cfg = HEADER_FILTERS[filterId];
    if (!cfg) continue;
    const v = String(cfg.valueOf(item));
    if (!allowed.has(v)) return false;
  }
  return true;
}

function applySort(table, items) {
  const sort = tableState[table].sort;
  if (!sort.length) return items;
  return items.slice().sort((a, b) => {
    for (const { col, dir } of sort) {
      const cfg = HEADER_FILTERS[col];
      if (!cfg) continue;
      const va = cfg.valueOf(a);
      const vb = cfg.valueOf(b);
      let cmp;
      if (cfg.type === 'num') {
        cmp = (Number(va) || 0) - (Number(vb) || 0);
      } else if (cfg.type === 'date') {
        // Parse "Jul 23" style — close enough for mock data sorting
        cmp = parseShortDate(va) - parseShortDate(vb);
      } else {
        cmp = String(va).localeCompare(String(vb));
      }
      if (cmp !== 0) return dir === 'desc' ? -cmp : cmp;
    }
    return 0;
  });
}

function parseShortDate(s) {
  if (!s) return 0;
  const months = { Jan:0, Feb:1, Mar:2, Apr:3, May:4, Jun:5, Jul:6, Aug:7, Sep:8, Oct:9, Nov:10, Dec:11 };
  const m = s.match(/(\w{3})\s*(\d+)/);
  if (!m) return 0;
  return (months[m[1]] || 0) * 100 + parseInt(m[2], 10);
}

// Build the menu
function toggleHeaderFilter(e, headerEl, filterId) {
  e.stopPropagation();
  const existing = headerEl.querySelector('.hf-menu');
  document.querySelectorAll('.hf-menu.open').forEach(m => m.remove());
  if (existing) return;

  const cfg = HEADER_FILTERS[filterId];
  if (!cfg) return;

  const tableKey = cfg.table;
  const renderFn = tableKey === 'deals' ? renderDeals : renderCompanies;

  const menu = document.createElement('div');
  menu.className = 'hf-menu open';

  // SORT section — labels adapt to type
  const sortLabels = {
    cat:  { asc: 'Sort A → Z', desc: 'Sort Z → A' },
    num:  { asc: 'Sort smallest to largest', desc: 'Sort largest to smallest' },
    date: { asc: 'Sort oldest to newest', desc: 'Sort newest to oldest' }
  };
  const labels = sortLabels[cfg.type] || sortLabels.cat;
  const currentSort = tableState[tableKey].sort.find(s => s.col === filterId);

  const sortSection = document.createElement('div');
  sortSection.className = 'hf-section';
  sortSection.innerHTML = `
    <div class="hf-sort-item ${currentSort?.dir === 'asc' ? 'on' : ''}" data-sort-dir="asc">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"/></svg>
      ${labels.asc}
    </div>
    <div class="hf-sort-item ${currentSort?.dir === 'desc' ? 'on' : ''}" data-sort-dir="desc">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      ${labels.desc}
    </div>
    ${currentSort ? `<div class="hf-action-item" data-sort-clear>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      Remove sort
    </div>` : ''}
  `;
  sortSection.addEventListener('click', (ev) => {
    const item = ev.target.closest('.hf-sort-item, [data-sort-clear]');
    if (!item) return;
    ev.stopPropagation();
    if (item.hasAttribute('data-sort-clear')) {
      tableState[tableKey].sort = tableState[tableKey].sort.filter(s => s.col !== filterId);
    } else {
      const dir = item.dataset.sortDir;
      const sortArr = tableState[tableKey].sort;
      const idx = sortArr.findIndex(s => s.col === filterId);
      if (idx >= 0) {
        sortArr[idx].dir = dir;
      } else {
        sortArr.push({ col: filterId, dir });
      }
    }
    renderFn();
    refreshAllHeaderIndicators();
    // Rebuild this menu to reflect new state
    headerEl.querySelector('.hf-menu')?.remove();
    toggleHeaderFilter({ stopPropagation: () => {} }, headerEl, filterId);
  });
  menu.appendChild(sortSection);

  // FILTER section (only for categorical columns with options)
  if (cfg.type === 'cat' && cfg.options) {
    const allOpts = cfg.options();
    const currentFilter = tableState[tableKey].filters[filterId];

    const searchSection = document.createElement('div');
    searchSection.className = 'hf-search';
    searchSection.innerHTML = `<input type="text" placeholder="Search…" autocomplete="off">`;

    const checksSection = document.createElement('div');
    checksSection.className = 'hf-checks';

    const renderChecks = (filterText = '') => {
      const visible = allOpts.filter(o => o.label.toLowerCase().includes(filterText.toLowerCase()));
      const allChecked = !currentFilter || allOpts.every(o => currentFilter.has(o.value));
      checksSection.innerHTML = `
        <div class="hf-check-item ${allChecked ? 'on' : ''}" data-select-all>
          <span class="hf-cb"></span><span class="label">(Select all)</span>
        </div>
        ${visible.map(o => {
          const isChecked = !currentFilter || currentFilter.has(o.value);
          return `<div class="hf-check-item ${isChecked ? 'on' : ''}" data-value="${o.value.replace(/"/g, '&quot;')}">
            <span class="hf-cb"></span><span class="label">${o.label}</span>
          </div>`;
        }).join('')}
      `;
    };
    renderChecks();

    searchSection.querySelector('input').addEventListener('input', (ev) => {
      ev.stopPropagation();
      renderChecks(ev.target.value);
    });
    searchSection.querySelector('input').addEventListener('click', (ev) => ev.stopPropagation());

    checksSection.addEventListener('click', (ev) => {
      ev.stopPropagation();
      const item = ev.target.closest('.hf-check-item');
      if (!item) return;

      let f = tableState[tableKey].filters[filterId];
      // Initialize: if no filter set, treat as all-checked
      if (!f) {
        f = new Set(allOpts.map(o => o.value));
      }

      if (item.hasAttribute('data-select-all')) {
        const allChecked = allOpts.every(o => f.has(o.value));
        if (allChecked) {
          f = new Set();
        } else {
          f = new Set(allOpts.map(o => o.value));
        }
      } else {
        const v = item.dataset.value;
        if (f.has(v)) f.delete(v); else f.add(v);
      }

      // If all options are checked, remove the filter (means "no filter")
      if (allOpts.every(o => f.has(o.value))) {
        delete tableState[tableKey].filters[filterId];
      } else if (f.size === 0) {
        // Empty set = nothing matches; keep it (user unchecked everything)
        tableState[tableKey].filters[filterId] = f;
      } else {
        tableState[tableKey].filters[filterId] = f;
      }

      // Rerender checks + table
      renderChecks(searchSection.querySelector('input').value);
      renderFn();
      refreshAllHeaderIndicators();
    });

    const footSection = document.createElement('div');
    footSection.className = 'hf-foot';
    footSection.innerHTML = `<button data-clear-filter>Clear filter</button>`;
    footSection.addEventListener('click', (ev) => {
      ev.stopPropagation();
      delete tableState[tableKey].filters[filterId];
      renderFn();
      refreshAllHeaderIndicators();
      headerEl.querySelector('.hf-menu')?.remove();
    });

    menu.appendChild(searchSection);
    menu.appendChild(checksSection);
    menu.appendChild(footSection);
  }

  headerEl.appendChild(menu);
}

function refreshAllHeaderIndicators() {
  document.querySelectorAll('.dv-th[id]').forEach(th => {
    const filterId = th.id.replace(/^.*?-th-/, '').match(/^(.+)$/)?.[1];
    // Match either explicit data filter binding or convention
    const explicitFilterId = th.getAttribute('data-filter-id') || (function() {
      // Scan onclick to extract the filterId argument
      const oc = th.getAttribute('onclick') || '';
      const m = oc.match(/'([^']+)'\)$/);
      return m ? m[1] : null;
    })();
    if (!explicitFilterId) return;
    updateHeaderIndicator(th, explicitFilterId);
  });
}

function updateHeaderIndicator(headerEl, filterId) {
  const cfg = HEADER_FILTERS[filterId];
  if (!cfg) return;
  const tableKey = cfg.table;
  const sortIdx = tableState[tableKey].sort.findIndex(s => s.col === filterId);
  const sortEntry = sortIdx >= 0 ? tableState[tableKey].sort[sortIdx] : null;
  const hasFilter = !!tableState[tableKey].filters[filterId];

  // Remove existing indicators
  headerEl.querySelector('.hf-indicator')?.remove();
  headerEl.classList.toggle('has-filter', hasFilter);

  if (sortEntry || hasFilter) {
    const ind = document.createElement('span');
    ind.className = 'hf-indicator';
    let html = '';
    if (sortEntry) {
      html += sortEntry.dir === 'asc'
        ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"/></svg>'
        : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>';
      // Only show priority number if there are 2+ sorts
      if (tableState[tableKey].sort.length > 1) {
        html += '<span class="hf-sort-num">' + (sortIdx + 1) + '</span>';
      }
    }
    if (hasFilter) {
      html += '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>';
    }
    ind.innerHTML = html;
    headerEl.appendChild(ind);
  }
}

