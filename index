  filterOwner: 'all',
  filterStage: 'all',
  savedView: 'all'
};

function fmtValue(v) {
  if (v >= 1000000) return '$' + (v/1000000).toFixed(2).replace(/\.?0+$/, '') + 'M';
  if (v >= 1000) return '$' + (v/1000).toFixed(0) + 'K';
  return '$' + v;
}

function daysClass(d) {
  if (d >= 60) return 'danger';
  if (d >= 30) return 'warn';
  return '';
}

function getFiltered() {
  return DEALS.filter(d => {
    // Saved view filter
    if (dealsState.savedView === 'risk') {
      const isRed = d.temperature && d.temperature.toLowerCase().startsWith('red');
      const longStall = d.stalledDays >= 60;
      if (!isRed && !longStall) return false;
    }
    if (dealsState.savedView === 'won') {
      if (d.stage !== 'Won') return false;
    }
    if (dealsState.hideStalled && d.stalledDays > 0) return false;
    // Excel-style column filters
    if (!passesColumnFilters('deals', d)) return false;
    return true;
  });
}

function renderList() {
  const tbody = document.getElementById('dv-tbody');
  const deals = applySort('deals', getFiltered());

  tbody.innerHTML = deals.map(d => {
    const sc = STAGE_COLORS[d.stage];
    const isStalled = d.stalledDays > 0;
    const isLost = d.stage === 'Lost';
    const isWon = d.stage === 'Won';
    const cls = ['dv-tr'];
    if (isStalled) cls.push('stalled');
    if (isLost) cls.push('lost');
    if (isWon) cls.push('won');

    // Stage cell — when stalled, replace stage with italic grey "Stalled (Xd)"
    const stageHtml = isStalled
      ? `<span class="dv-stage-stalled">Stalled · ${d.stalledDays}d</span>`
      : `<span class="dv-stage" style="color:${sc.text}"><span class="dv-stage-dot" style="background:${sc.dot}"></span>${d.stage}</span>`;

    // Temperature cell — colored dot + reason text
    const temp = parseTemp(d.temperature);
    const tempHtml = temp
      ? `<span class="dv-flag" style="color:${FLAG_COLORS[temp.color].text}" title="${d.temperature}"><span class="dv-flag-dot" style="background:${FLAG_COLORS[temp.color].dot}"></span><span class="dv-flag-text">${temp.reason || (temp.color.charAt(0).toUpperCase() + temp.color.slice(1))}</span></span>`
      : '<span style="color:var(--color-text-tertiary); font-size:11px">—</span>';

    return `<div class="${cls.join(' ')}" data-deal-id="${d.id}" onclick="openDealDrawer(${d.id})">
      <div class="dv-td dv-co"><span class="dv-co-name">${d.company}</span></div>
      <div class="dv-td"><span class="dv-tk">${d.ticker}</span></div>
      <div class="dv-td"><span class="dv-hq">${d.hq}</span></div>
      <div class="dv-td"><span class="dv-deal">${d.deal}</span></div>
      <div class="dv-td">${stageHtml}</div>
      <div class="dv-td"><span class="dv-val">${fmtValue(d.value)}<span class="dv-cur-tag">${d.currency}</span></span></div>
      <div class="dv-td"><span class="dv-days ${daysClass(d.days)}">${d.days}d</span></div>
      <div class="dv-td"><span class="dv-av" title="${d.ownerName}">${d.owner}</span></div>
      <div class="dv-td">${tempHtml}</div>
      <div class="dv-td"><span class="dv-next">${d.nextStep}</span></div>
    </div>`;
  }).join('');
}

function renderKanban() {
  const board = document.getElementById('dv-kb');
  const stages = ["In conversation", "Proposal", "Contract", "Won", "Lost"];
  const filtered = getFiltered();

  board.innerHTML = stages.map(stage => {
    const sc = STAGE_COLORS[stage];
    const stageDeals = filtered.filter(d => d.stage === stage);
    const totalVal = stageDeals.filter(d => d.currency === 'USD').reduce((s, d) => s + d.value, 0);
    const valLabel = stageDeals.length ? (totalVal > 0 ? fmtValue(totalVal) : '—') : '';

    const cards = stageDeals.map(d => {
      const isStalled = d.stalledDays > 0;
      const cardCls = ['dv-card'];
      if (isStalled) cardCls.push('stalled');
      if (stage === 'Lost') cardCls.push('lost');

      const tempParsed = parseTemp(d.temperature);
      const flagDot = tempParsed
        ? `<span class="dv-card-flag-dot" style="background:${FLAG_COLORS[tempParsed.color].dot}" title="${d.temperature}"></span>`
        : '';

      const stalledLabel = isStalled ? `<span style="color:var(--color-text-tertiary)">Stalled ${d.stalledDays}d</span>` : `<span>${d.days}d ago</span>`;

      return `<div class="${cardCls.join(' ')}" data-deal-id="${d.id}" onclick="openDealDrawer(${d.id})">
        <div class="dv-card-co">${d.company}</div>
        <div class="dv-card-deal">${d.deal}</div>
        <div class="dv-card-row">
          <span class="dv-card-val">${fmtValue(d.value)}<span class="dv-card-cur">${d.currency}</span></span>
          <span class="dv-av" title="${d.ownerName}" style="width:20px; height:20px; font-size:9px">${d.owner}</span>
        </div>
        <div class="dv-card-meta">
          <span class="dv-card-meta-l">${flagDot}${stalledLabel}</span>
        </div>
      </div>`;
    }).join('');

    return `<div class="dv-kc">
      <div class="dv-kc-h">
        <span class="dv-kc-h-left"><span class="dv-kc-dot" style="background:${sc.dot}"></span>${stage}<span class="dv-kc-c">${stageDeals.length}</span></span>
        <span class="dv-kc-c">${valLabel}</span>
      </div>
      ${cards || '<div style="color:var(--color-text-tertiary); font-size:11px; padding:8px 4px; text-align:center">No deals</div>'}
    </div>`;
  }).join('');
}

function updateStats() {
  const filtered = getFiltered();
  const open = filtered.filter(d => !['Won', 'Lost'].includes(d.stage));
  const openUSD = open.filter(d => d.currency === 'USD').reduce((s, d) => s + d.value, 0);
  const stalledDeals = filtered.filter(d => d.stalledDays > 0);
  const stalledUSD = stalledDeals.filter(d => d.currency === 'USD').reduce((s, d) => s + d.value, 0);
  const risk = filtered.filter(d => (d.temperature && d.temperature.toLowerCase().startsWith('red')) || d.stalledDays >= 60).length;

  // Win rate over last 90d — closed deals (Won or Lost) where days <= 90
  const closedRecent = DEALS.filter(d => ['Won', 'Lost'].includes(d.stage) && d.days <= 90);
  const wonRecent = closedRecent.filter(d => d.stage === 'Won').length;
  const winRate = closedRecent.length > 0 ? Math.round(100 * wonRecent / closedRecent.length) : null;

  document.getElementById('stat-open').textContent = `${open.length} deals · ${fmtValue(openUSD)}`;
  document.getElementById('stat-stalled').textContent = stalledDeals.length === 0 ? '0' : `${stalledDeals.length} · ${fmtValue(stalledUSD)}`;
  document.getElementById('stat-risk').textContent = risk;
  document.getElementById('stat-winrate').textContent = winRate === null ? '—' : `${winRate}% · ${wonRecent} of ${closedRecent.length}`;

  document.getElementById('count-all').textContent = DEALS.length;
  document.getElementById('count-risk').textContent = DEALS.filter(d => (d.temperature && d.temperature.toLowerCase().startsWith('red')) || d.stalledDays >= 60).length;
  document.getElementById('count-won').textContent = DEALS.filter(d => d.stage === 'Won').length;
}

function renderDeals() {
  if (dealsState.view === 'list') renderList();
  else renderKanban();
  updateStats();
}



