const _origPassesColumnFilters = passesColumnFilters;
window.passesColumnFilters = function(table, item) {
  if (table === 'people' && tableState.people.filters['pv-flags']) {
    const allowed = tableState.people.filters['pv-flags'];
    const itemFlags = item.flags && item.flags.length ? item.flags : ['—'];
    const matches = itemFlags.some(f => allowed.has(f));
    if (!matches) return false;
    // Now check other filters except pv-flags
    for (const [filterId, vals] of Object.entries(tableState.people.filters)) {
      if (filterId === 'pv-flags') continue;
      const cfg = HEADER_FILTERS[filterId];
      if (!cfg || !vals) continue;
      if (!vals.has(String(cfg.valueOf(item)))) return false;
    }
    return true;
  }
  return _origPassesColumnFilters(table, item);
};




