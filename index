<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Rose &amp; Co — Ridgeline Energy</title>
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
<style>
@import url('https://cdn.jsdelivr.net/npm/@fontsource/inter@4.5.15/400.css');
@import url('https://cdn.jsdelivr.net/npm/@fontsource/inter@4.5.15/500.css');

:root {
  --color-text-primary: #1A1A1A;
  --color-text-secondary: #5C5C5C;
  --color-text-tertiary: #8E8E8E;
  --color-text-info: #2563EB;
  --color-text-warning: #A16207;
  --color-text-danger: #DC2626;
  --color-text-success: #059669;
  --color-background-primary: #FFFFFF;
  --color-background-secondary: #F4F4F5;
  --color-background-tertiary: #E4E4E7;
  --color-background-info: #DBEAFE;
  --color-background-warning: #FEF3C7;
  --color-background-danger: #FEE2E2;
  --color-background-success: #D1FAE5;
  --color-border-tertiary: rgba(0, 0, 0, 0.08);
  --color-border-secondary: rgba(0, 0, 0, 0.16);
  --color-border-primary: rgba(0, 0, 0, 0.24);
  --crm-grey-bg: #F0F0F2;
  --crm-grey-text: #6B6B6E;
  --side-bg: #F7F7F8;
  --side-border: #E5E5E7;
  --hover-bg: rgba(0, 0, 0, 0.025);
}

@media (prefers-color-scheme: dark) {
  :root {
    --color-text-primary: #F5F5F5;
    --color-text-secondary: #A1A1A6;
    --color-text-tertiary: #6F6F73;
    --color-text-info: #60A5FA;
    --color-text-warning: #FBBF24;
    --color-text-danger: #F87171;
    --color-text-success: #34D399;
    --color-background-primary: #0F0F11;
    --color-background-secondary: #1E1E20;
    --color-background-tertiary: #2A2A2C;
    --color-background-info: rgba(37, 99, 235, 0.20);
    --color-background-warning: rgba(245, 158, 11, 0.18);
    --color-background-danger: rgba(239, 68, 68, 0.18);
    --color-background-success: rgba(16, 185, 129, 0.18);
    --color-border-tertiary: rgba(255, 255, 255, 0.08);
    --color-border-secondary: rgba(255, 255, 255, 0.16);
    --color-border-primary: rgba(255, 255, 255, 0.24);
    --crm-grey-bg: #2C2C2E;
    --crm-grey-text: #9E9E9E;
    --side-bg: #1C1C1E;
    --side-border: #2D2D30;
    --hover-bg: rgba(255, 255, 255, 0.04);
  }
  .o-proposal { color: #93C5FD !important; }
  .o-proposal-dot { background: #93C5FD !important;
  }
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }
body {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  font-size: 13px;
  color: var(--color-text-primary);
  background: var(--color-background-primary);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
button { font-family: inherit; }

.app { display: flex; height: 100vh; }

.side {
  width: 200px;
  flex-shrink: 0;
  padding: 12px 8px;
  background: var(--side-bg);
  border-right: 0.5px solid var(--side-border);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}
.ws { display: flex; align-items: center; gap: 8px; padding: 4px 6px 14px; }
.ws-logo {
  width: 26px; height: 26px;
  border-radius: 4px;
  flex-shrink: 0;
  object-fit: cover;
  display: block;
}
.ws-name { font-size: 13px; font-weight: 500; color: var(--color-text-primary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; }
.ws-chev { color: var(--color-text-tertiary); display: flex; }
.ws-chev svg { width: 12px; height: 12px; }

.nav { display: flex; flex-direction: column; gap: 1px; }
.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 6px 8px; font-size: 13px;
  color: var(--color-text-secondary); text-decoration: none;
  border-radius: 5px; cursor: pointer; font-weight: 400; line-height: 1;
  user-select: none;
}
.nav-item:hover { background: rgba(0, 0, 0, 0.04); color: var(--color-text-primary); }
.nav-item.on { background: rgba(0, 0, 0, 0.06); color: var(--color-text-primary); font-weight: 500; }
@media (prefers-color-scheme: dark) {
  .nav-item:hover { background: rgba(255, 255, 255, 0.04); }
  .nav-item.on { background: rgba(255, 255, 255, 0.07); }
}
.nav-item svg { width: 15px; height: 15px; stroke-width: 1.5; flex-shrink: 0; opacity: 0.85; }

.divider { height: 0.5px; background: rgba(0, 0, 0, 0.08); margin: 12px 4px; }
@media (prefers-color-scheme: dark) { .divider { background: rgba(255, 255, 255, 0.08); } }
.label { font-size: 11px; color: var(--color-text-tertiary); padding: 2px 8px 6px; font-weight: 500; }

.main {
  flex: 1; min-width: 0;
  overflow-y: auto;
  padding: 18px 28px 32px;
  background: var(--color-background-primary);
}
.main-inner { max-width: 1100px; }

.top {
  display: flex; justify-content: space-between; align-items: center;
  padding-bottom: 14px;
  border-bottom: 0.5px solid var(--color-border-tertiary);
  margin-bottom: 18px;
}
.bc { font-size: 12px; color: var(--color-text-tertiary); }
.bc .cur { color: var(--color-text-primary); font-weight: 500; }
.bc-sep { margin: 0 6px; opacity: 0.5; }
.acts { display: flex; gap: 6px; }
.btn {
  font-size: 11px; padding: 6px 12px;
  background: transparent;
  border: 0.5px solid var(--color-border-secondary);
  border-radius: 5px; color: var(--color-text-primary);
  cursor: pointer; font-weight: 400;
  display: inline-flex; align-items: center; gap: 6px;
  transition: background 0.12s;
  line-height: 1.3;
}
.btn:hover { background: var(--color-background-secondary); }
.btn svg { width: 12px; height: 12px; flex-shrink: 0; }

.hero { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 14px; gap: 16px; }
.hero h1 { font-size: 24px; font-weight: 500; margin: 0 0 8px; line-height: 1.15; letter-spacing: -0.015em; }
.tags { display: flex; gap: 5px; align-items: center; flex-wrap: wrap; margin-bottom: 8px; }
.tag {
  font-size: 11px; padding: 2px 7px; border-radius: 4px;
  background: var(--crm-grey-bg); color: var(--crm-grey-text);
  font-family: ui-monospace, monospace; font-weight: 500; letter-spacing: 0.02em;
}
.pill {
  font-size: 11px; padding: 2px 9px; border-radius: 999px;
  background: var(--color-background-info); color: var(--color-text-info);
  font-weight: 500;
}
.stage {
  font-size: 11px; padding: 2px 9px; border-radius: 999px;
  background: var(--color-background-info); color: var(--color-text-info); font-weight: 500;
}
.desc { font-size: 12px; color: var(--color-text-secondary); line-height: 1.55; max-width: 540px; margin: 0; }


.own { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
.own-l { font-size: 11px; color: var(--color-text-tertiary); margin-right: 2px; }
.av {
  width: 26px; height: 26px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 500;
  border: 0.5px solid var(--color-border-tertiary);
  background: var(--crm-grey-bg); color: var(--crm-grey-text);
  cursor: default;
}

.own-col { display: flex; flex-direction: column; align-items: flex-end; gap: 12px; flex-shrink: 0; }
.hero-earn { display: flex; flex-direction: column; gap: 4px; align-items: flex-end; }
.he-row { display: flex; gap: 8px; align-items: baseline; }
.he-l { color: var(--color-text-tertiary); font-size: 11px; font-weight: 500; letter-spacing: 0.02em; }
.he-v { color: var(--color-text-primary); font-size: 12px; font-weight: 400; }

.strip {
  display: flex; align-items: center; flex-wrap: wrap; gap: 10px 12px;
  padding: 10px 0 14px; margin-bottom: 18px;
  border-bottom: 0.5px solid var(--color-border-tertiary);
  font-size: 12px; color: var(--color-text-secondary);
}
.strip-item { display: inline-flex; align-items: center; gap: 6px; }
.strip-l { color: var(--color-text-tertiary); font-size: 11px; font-weight: 500; letter-spacing: 0.02em; }
.strip-v { color: var(--color-text-primary); font-weight: 400; }
.strip-sep { color: var(--color-text-tertiary); opacity: 0.4; }
.strip-link {
  color: var(--color-text-info); text-decoration: none;
  display: inline-flex; align-items: center; gap: 3px;
}
.strip-link:hover { text-decoration: underline; }
.strip-link svg { width: 10px; height: 10px; opacity: 0.7; }

.facts { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 8px; margin-bottom: 20px; }
.fact { padding: 11px 13px; border: 0.5px solid var(--color-border-tertiary); border-radius: 8px; }
.fact-l { font-size: 11px; color: var(--color-text-tertiary); margin-bottom: 4px; }
.fact-v { font-size: 13px; font-weight: 500; color: var(--color-text-primary); }
.fact-sub { font-weight: 400; color: var(--color-text-tertiary); font-size: 12px; margin-left: 2px; }

.row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
.card { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: 8px; padding: 13px 15px; }
.card h3 { font-size: 12px; font-weight: 500; margin: 0 0 11px; display: flex; justify-content: space-between; align-items: center; color: var(--color-text-secondary); letter-spacing: 0.02em; gap: 8px; }
.card h3 .c { color: var(--color-text-tertiary); font-weight: 400; transition: color 0.12s; }
.card h3 .h-left {
  display: inline-flex; align-items: center; gap: 6px;
  cursor: pointer; transition: color 0.12s;
  border-radius: 4px;
}
.card h3 .h-left:hover { color: var(--color-text-primary); }
.card h3 .h-left:hover .c { color: var(--color-text-info); }

.card h3 .h-past {
  display: inline-flex; align-items: center; gap: 4px;
  cursor: pointer;
  color: var(--color-text-tertiary);
  font-weight: 400;
  opacity: 0.7;
  transition: opacity 0.12s, color 0.12s;
  margin-left: auto;
}
.card h3 .h-past:hover { opacity: 1; color: var(--color-text-secondary); }
.card h3 .h-past .c { color: var(--color-text-tertiary); }

.ir-pill { font-size: 11px; padding: 2px 7px; border-radius: 4px; background: var(--color-background-danger); color: var(--color-text-danger); font-weight: 500; }
.fc-pill { font-size: 10px; padding: 1px 6px; border-radius: 4px; background: var(--color-background-success); color: var(--color-text-success); font-weight: 500; margin-left: 6px; vertical-align: 1px; }
.dnc-pill { font-size: 10px; padding: 1px 6px; border-radius: 4px; background: var(--color-background-danger); color: var(--color-text-danger); font-weight: 500; margin-left: 6px; vertical-align: 1px; }

.p, .o, .m-item, .ev {
  cursor: pointer;
  transition: background 0.12s;
  border-radius: 4px;
}
.p:hover, .o:hover, .m-item:hover, .ev:hover { background: var(--hover-bg); }
.t-item:hover { background: var(--hover-bg); border-radius: 4px; }
.p:hover .p-t, .m-item:hover .m-meta, .ev:hover .ev-b { color: var(--color-text-secondary); }

.p { display: flex; align-items: center; gap: 9px; padding: 7px 6px; margin: 0 -6px; border-top: 0.5px solid var(--color-border-tertiary); }
.p:first-of-type { border-top: none; padding-top: 4px; }
.p-info { flex: 1; min-width: 0; }
.p-n { font-size: 12px; font-weight: 500; color: var(--color-text-primary); }
.p-t { font-size: 11px; color: var(--color-text-tertiary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; transition: color 0.12s; }

.p-acts { display: flex; gap: 1px; flex-shrink: 0; }
.p-act {
  width: 24px; height: 24px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 4px; background: transparent; border: none;
  color: var(--color-text-tertiary);
  cursor: pointer;
  opacity: 0.55;
  transition: background 0.12s, color 0.12s, opacity 0.12s;
}
.p:hover .p-act { opacity: 1; }
.p-act:hover { background: var(--color-background-secondary); color: var(--color-text-primary); }
.p-act svg { width: 14px; height: 14px; }
.p-act.li img { width: 14px; height: 14px; display: block; border-radius: 2px; }
.p-act.li { opacity: 0.85; }
.p:hover .p-act.li { opacity: 1; }
.p-act.li:hover { background: var(--color-background-secondary); }

.o { padding: 9px 6px; margin: 0 -6px; border-top: 0.5px solid var(--color-border-tertiary); }
.o:first-of-type { border-top: none; padding-top: 4px; }
.o-h { display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px; gap: 6px; }
.o-t { font-size: 11px; padding: 2px 7px; border-radius: 4px; background: var(--crm-grey-bg); color: var(--crm-grey-text); font-weight: 500; }
.o-f { font-size: 13px; font-weight: 500; color: var(--color-text-primary); }
.o-cur { color: var(--color-text-tertiary); font-size: 11px; font-weight: 400; margin-left: 4px; letter-spacing: 0.03em; }
.o-m { font-size: 11px; color: var(--color-text-tertiary); line-height: 1.55; display: flex; flex-wrap: wrap; align-items: center; gap: 5px; }
.o-flag { display: inline-flex; align-items: center; gap: 4px; color: #A16207; font-weight: 500; }
.o-dot { width: 7px; height: 7px; border-radius: 50%; background: #EAB308; }
.o.stalled { opacity: 0.6; }
.o.stalled .o-f { color: var(--color-text-tertiary); }
.o-stall { display: inline-flex; align-items: center; gap: 4px; color: var(--color-text-tertiary); font-weight: 500; }
.o-stall-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--color-text-tertiary); }
.o-active { display: inline-flex; align-items: center; gap: 4px; color: var(--color-text-success); font-weight: 500; }
.o-active-dot { width: 7px; height: 7px; border-radius: 50%; background: #10B981; }
.o-proposal { display: inline-flex; align-items: center; gap: 4px; color: #1E40AF; font-weight: 500; }
.o-proposal-dot { width: 7px; height: 7px; border-radius: 50%; background: #3B82F6; }
.o-lost { display: inline-flex; align-items: center; gap: 4px; color: var(--color-text-danger); font-weight: 500; }
.o-lost-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--color-text-danger); }
.o.lost { opacity: 0.6; }
.o.lost .o-f { color: var(--color-text-tertiary); }

.m-item { display: flex; gap: 8px; align-items: flex-start; padding: 9px 6px; margin: 0 -6px; border-top: 0.5px solid var(--color-border-tertiary); }
.m-item:first-of-type { border-top: none; padding-top: 4px; }
.m-acts { display: flex; gap: 1px; flex-shrink: 0; padding-top: 1px; }
.m-act {
  width: 22px; height: 22px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 4px; background: transparent; border: none;
  color: var(--color-text-tertiary);
  cursor: pointer;
  opacity: 0.55;
  transition: background 0.12s, color 0.12s, opacity 0.12s;
}
.m-item:hover .m-act { opacity: 1; }
.m-act:hover { background: var(--color-background-secondary); color: var(--color-text-primary); }
.m-act svg { width: 13px; height: 13px; }
.m-content { flex: 1; min-width: 0; }
.m-when { font-size: 11px; color: var(--color-text-secondary); font-weight: 500; margin-bottom: 2px; }
.m-title { font-size: 12px; font-weight: 500; color: var(--color-text-primary); margin-bottom: 2px; line-height: 1.35; }
.m-meta { font-size: 11px; color: var(--color-text-tertiary); line-height: 1.4; transition: color 0.12s; }

.t-item { display: flex; gap: 9px; align-items: flex-start; padding: 8px 6px; margin: 0 -6px; border-top: 0.5px solid var(--color-border-tertiary); cursor: default; transition: background 0.12s; }
.t-item:first-of-type { border-top: none; padding-top: 4px; }
.t-check {
  width: 14px; height: 14px; border-radius: 4px;
  border: 1px solid var(--color-border-secondary);
  flex-shrink: 0; margin-top: 1px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.12s, border-color 0.12s;
}
.t-check.checked { background: var(--color-text-primary); border-color: var(--color-text-primary); }
.t-check.checked::after {
  content: ''; display: block;
  width: 4px; height: 7px;
  border: 1.5px solid var(--color-background-primary);
  border-top: none; border-left: none;
  transform: rotate(45deg) translate(-1px, -1px);
}
.t-info { flex: 1; min-width: 0; cursor: pointer; }
.t-title { font-size: 12px; font-weight: 500; color: var(--color-text-primary); margin-bottom: 2px; line-height: 1.35; transition: opacity 0.12s; }
.t-meta { font-size: 11px; color: var(--color-text-tertiary); }
.t-due { font-weight: 500; color: var(--color-text-secondary); }
.t-due.urgent { color: var(--color-text-danger); }
.t-item.done .t-title { opacity: 0.5; text-decoration: line-through; }

.tlh { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.tlh h2 { font-size: 14px; font-weight: 500; margin: 0; color: var(--color-text-primary); }
.flt { display: flex; gap: 1px; font-size: 11px; }
.flt span { padding: 4px 8px; border-radius: 5px; color: var(--color-text-tertiary); cursor: pointer; font-weight: 400; user-select: none; }
.flt span:hover { color: var(--color-text-secondary); }
.flt span.on { background: var(--crm-grey-bg); color: var(--color-text-primary); }

.tl { position: relative; padding-left: 18px; }
.tl::before { content: ''; position: absolute; left: 4.5px; top: 5px; bottom: 5px; width: 0.5px; background: var(--color-border-tertiary); }
.ev { position: relative; padding: 6px 6px 16px; margin: 0 -6px; }
.ev::before { content: ''; position: absolute; left: -12px; top: 11px; width: 9px; height: 9px; border-radius: 50%; background: var(--color-background-primary); border: 0.5px solid var(--color-border-secondary); }
.ev-h { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; margin-bottom: 3px; }
.ev-t { font-size: 12px; font-weight: 500; flex: 1; min-width: 0; color: var(--color-text-primary); }
.ev-m { font-size: 11px; color: var(--color-text-tertiary); white-space: nowrap; flex-shrink: 0; }
.ev-b { font-size: 11px; color: var(--color-text-secondary); line-height: 1.55; transition: color 0.12s; }
.ev-typ { display: inline-block; font-size: 10px; padding: 1px 6px; border-radius: 3px; background: var(--crm-grey-bg); color: var(--crm-grey-text); margin-right: 6px; font-weight: 500; letter-spacing: 0.02em; }


/* ========== MODALS & DRAWERS ========== */
[hidden] { display: none !important; }

.modal-scrim, .drawer-scrim {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  display: flex;
  animation: fadein 0.15s ease-out;
}
.modal-scrim { align-items: center; justify-content: center; }
.drawer-scrim { justify-content: flex-end; }
@keyframes fadein { from { opacity: 0; } to { opacity: 1; } }
@keyframes slidein { from { transform: translateX(100%); } to { transform: translateX(0); } }

.modal-card {
  background: var(--color-background-primary);
  border: 0.5px solid var(--color-border-tertiary);
  border-radius: 10px;
  width: 460px; max-width: calc(100vw - 32px);
  max-height: calc(100vh - 64px);
  display: flex; flex-direction: column;
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.18);
  overflow: hidden;
}

.drawer {
  background: var(--color-background-primary);
  border-left: 0.5px solid var(--color-border-tertiary);
  width: 560px; max-width: calc(100vw - 32px);
  height: 100vh;
  display: flex; flex-direction: column;
  box-shadow: -12px 0 40px rgba(0, 0, 0, 0.18);
  animation: slidein 0.2s ease-out;
}

.m-head {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 18px;
  border-bottom: 0.5px solid var(--color-border-tertiary);
  flex-shrink: 0;
}
.m-title { font-size: 14px; font-weight: 500; color: var(--color-text-primary); }
.m-x {
  width: 26px; height: 26px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 5px;
  background: transparent; border: none;
  color: var(--color-text-tertiary); cursor: pointer;
  transition: background 0.12s, color 0.12s;
}
.m-x:hover { background: var(--color-background-secondary); color: var(--color-text-primary); }
.m-x svg { width: 14px; height: 14px; }

.m-body { padding: 16px 18px; overflow-y: auto; flex: 1; }
.m-foot {
  padding: 12px 18px;
  border-top: 0.5px solid var(--color-border-tertiary);
  display: flex; justify-content: flex-end; gap: 6px;
  flex-shrink: 0;
}

/* Form fields */
.field { margin-bottom: 14px; }
.field-label { display: block; font-size: 11px; color: var(--color-text-tertiary); font-weight: 500; margin-bottom: 5px; letter-spacing: 0.02em; }
.field-input, .field-select, .field-textarea {
  width: 100%;
  font-family: inherit; font-size: 13px;
  padding: 7px 10px;
  background: var(--color-background-primary);
  color: var(--color-text-primary);
  border: 0.5px solid var(--color-border-secondary);
  border-radius: 5px;
  outline: none;
